# Copy this file to .env and fill in your values.
# The .env file is git-ignored so your key stays private.

# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: change the model (default is gpt-4o-mini — cheap and fast)
# OPENAI_MODEL=gpt-4o-mini

# Optional: Flask secret key (any random string is fine for local dev)
# SECRET_KEY=change_me_in_production

# Set to "1" to enable Flask debug mode (local development only)
# FLASK_DEBUG=0
